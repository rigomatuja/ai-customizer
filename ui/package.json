{
  "name": "ai-customizer-ui",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "description": "Local UI for AI Customizer — catalog browser + installer",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:server:dev\" \"npm:client:dev\"",
    "client:dev": "vite",
    "server:dev": "tsx watch src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tar": "^7.5.13",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/tar": "^6.1.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
